# --- Server ---
# Railway Postgres connection string (Variables → DATABASE_URL — auto-injected by Railway when you add a Postgres plugin)
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartclub
# Long random secret for signing JWT tokens (generate: openssl rand -hex 32)
JWT_SECRET=replace-me-with-a-long-random-string
# HTTP port (Railway sets PORT automatically)
PORT=4000
